# Option 1: Poe API Key (get one at https://poe.com/api/keys)
# Uses Gemini-3-Pro with web search. Supports many AI models.
# POE_API_KEY=your-poe-key

# Option 2: OpenRouter API Key (get one at https://openrouter.ai/keys)
# OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Option 3: OpenAI API Key (get one at https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-your-key-here
